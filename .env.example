# ==============================================================================
# MCP TRON Server - Environment Variables Example
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------

# The port the HTTP server will listen on (default: 3001)
# MCP_PORT=3001

# The host the HTTP server will bind to (default: 0.0.0.0)
# MCP_HOST=0.0.0.0

# Log directory path (default: ./logs)
# MCP_LOG_DIR=./logs

# Node environment (default: production)
# NODE_ENV=production

# ------------------------------------------------------------------------------
# Blockchain Configuration
# ------------------------------------------------------------------------------

# Optional: TronGrid API Key to avoid rate limits on Mainnet
# Get one at https://www.trongrid.io/
# TRONGRID_API_KEY=your_trongrid_api_key_here

# ------------------------------------------------------------------------------
# Wallet Configuration
# ------------------------------------------------------------------------------
# SECURITY NOTE: In readonly mode, these are not strictly required for most 
# operations, but providing a key allows tools like 'get_wallet_address' to work.
# NEVER commit your actual .env file to version control.

# Option 1: Hex Private Key
# TRON_PRIVATE_KEY=your_private_key_here

# Option 2: Mnemonic Phrase (12 or 24 words)
# TRON_MNEMONIC=word1 word2 ... word12
# TRON_ACCOUNT_INDEX=0
